{
  "name": "application-report",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "data": "tsx mission-control.ts > dist/mission-control.json",
    "html": "npm run data && facet html Application.tsx -d dist/mission-control.json -o dist",
    "pdf": "npm run data && facet pdf Application.tsx -d dist/mission-control.json -o dist",
    "mission-control": "npm run pdf"
  },
  "dependencies": {
    "@flanksource/facet": "^0.1.32",
    "@flanksource/icons": "^1.0.53",
        "@iconify-json/carbon": "^1.2.0",
    "@iconify-json/fluent": "^1.2.0",
    "@iconify-json/iconoir": "^1.2.0",                                                                                                                                  "@iconify-json/lucide": "^1.2.0",
    "@iconify-json/mdi": "^1.2.0",
    "@iconify-json/ph": "^1.2.0",
    "@iconify-json/ri": "^1.2.0",
    "@iconify-json/tabler": "^1.2.0",
    "@iconify-json/vscode-icons": "^1.2.45",
    "@iconify/react": "^5.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": ">=7.3.2"
  }
}
